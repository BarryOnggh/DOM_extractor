{
  "manifest_version": 3,
  "name": "GovAssist \u2014 AI Navigation Assistant",
  "version": "0.2.0",
  "description": "Walks you through government website tasks one step at a time.",
  "permissions": ["sidePanel", "activeTab", "scripting", "storage", "tabs"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "Open GovAssist"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
